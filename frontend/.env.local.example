# =========================================================================
# GRINDLOCK FRONTEND - LOCAL ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================

# 1. API Uplink Settings
# Point to your local or deployed backend API endpoint
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# 2. NextAuth Configuration
# Secret key used to encrypt Session JWT cookies. Generate using: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# NextAuth base URL (must match the frontend application host)
NEXTAUTH_URL=http://localhost:3000

# 3. Google OAuth Credentials (Google Cloud Console)
# Configure callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 4. GitHub OAuth Credentials (GitHub Developer Settings)
# Configure callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your_github_client_id_here
GITHUB_SECRET=your_github_client_secret_here

# 5. Shared Server-to-Server Verification Secret
# Must match the OAUTH_INTERNAL_SECRET configured on the backend
OAUTH_INTERNAL_SECRET=grindlock-fallback-oauth-internal-secret-key