# ==========================================
# GRINDLOCK PLATFORM ENVIRONMENT VARIABLES
# ==========================================

# ------------------------------------------
# Backend Service (Node.js/Express)
# ------------------------------------------
PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_super_secret_key_min_32_chars
APP_URL=http://localhost:3000
ANALYTICS_SERVICE_URL=http://localhost:8000
NODE_ENV=development

# Email Transmissions (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=no-reply@yourdomain.com

# Gamification Configuration
SEASONAL_EVENT_END_DATE=2026-12-31

# ------------------------------------------
# Frontend App (Next.js/React)
# ------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Set to 'true' to enable offline client mock/demo mode
NEXT_PUBLIC_DEMO_MODE=false

# ------------------------------------------
# Python Analytics Service
# ------------------------------------------
# PORT=8000
